# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# 可选：自定义 API Base URL（用于 Anthropic、Azure OpenAI 等兼容接口）
# OPENAI_API_BASE=https://api.anthropic.com/v1
OPENAI_API_BASE=https://your-custom-endpoint.com

# Model Configuration
OPENAI_MODEL=claude-haiku-4-5-20251001
# 使用 Anthropic 时，改为：claude-3-5-sonnet-20241022
# 使用 Azure OpenAI 时，改为你的部署名称

EMBEDDING_MODEL=text-embedding-3-small
# 注意：Anthropic 不支持 embeddings，需要使用 OpenAI 的 embedding 接口

# Chat Configuration
MAX_HISTORY_LENGTH=10
